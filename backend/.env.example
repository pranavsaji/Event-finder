# ============================================================
# SF Bay Area Events — Backend Environment Variables
# ============================================================
# Copy this file to .env and fill in your keys.
#   cp .env.example .env
#
# All API keys are OPTIONAL. The app scrapes 7 sources without
# any keys. Adding keys unlocks higher-quality data & more results.
# ============================================================

# ------------------------------------------------------------
# Eventbrite (optional)
# Without key: scrapes eventbrite.com (40-90 events)
# With key:    uses official API (higher limits, richer data)
# Get it free: https://www.eventbrite.com/platform/api
#              → Create App → copy "Private Token"
# ------------------------------------------------------------
EVENTBRITE_TOKEN=

# ------------------------------------------------------------
# Ticketmaster Discovery API (optional, recommended)
# Without key: no Ticketmaster events
# With key:    50 events per fetch (concerts, sports, shows)
# Get it free: https://developer.ticketmaster.com/products-and-docs/apis/getting-started/
#              → Register → My Apps → copy "Consumer Key"
# ------------------------------------------------------------
TICKETMASTER_API_KEY=
TICKETMASTER_SECRET=

# ------------------------------------------------------------
# Yelp Fusion API (optional)
# Without key: scrapes yelp.com/events/sf/browse (~34 events)
# With key:    uses official Events API (more filters, pagination)
# Get it free: https://www.yelp.com/developers/v3/manage_app
#              → Create App → copy "API Key" (NOT Client ID/Secret)
# ------------------------------------------------------------
YELP_API_KEY=

# ------------------------------------------------------------
# App settings (optional, defaults shown)
# ------------------------------------------------------------

# Comma-separated list of allowed CORS origins
# Default allows local Vite dev server
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173

# Rate limiting: max requests per window per IP
RATE_LIMIT=30
RATE_WINDOW=60

# Set to "production" to disable /docs endpoint
ENV=development
